{
  "family": "django-task",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::062104739456:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "django-container",
      "image": "062104739456.dkr.ecr.us-east-1.amazonaws.com/django-app:latest",
      "essential": true,
      "portMappings": [{"containerPort": 8000, "hostPort": 0, "protocol": "tcp"}],
      "environment": [
        {"name": "DJANGO_SETTINGS_MODULE", "value": "hello_world_django_app.settings"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/django-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
